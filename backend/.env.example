# Server Configuration
PORT=5000
NODE_ENV=development

# Database - Docker MongoDB (using port 27018 to avoid conflicts)
MONGODB_URI=mongodb://admin:password123@localhost:27018/todoapp?authSource=admin

# Alternative database connection for app-specific user
# MONGODB_URI=mongodb://todouser:todopass123@localhost:27017/todoapp

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

